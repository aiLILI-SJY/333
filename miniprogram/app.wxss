/* 全局样式 - 见世界设计系统 */
page {
  --color-primary: #1A73E8;
  --color-primary-dark: #005bbf;
  --color-primary-fixed: #d8e2ff;
  --color-primary-tint: #E8F0FE;
  --color-secondary: #006e2a;
  --color-secondary-tint: #E8F5E9;
  --color-tertiary: #9e4300;
  --color-tertiary-container: #c55500;
  --color-error: #ba1a1a;
  --color-error-container: #ffdad6;
  --color-on-error-container: #93000a;

  --color-bg: #F8F9FA;
  --color-surface: #FFFFFF;
  --color-surface-container-low: #f2f3fd;
  --color-surface-container: #ecedf7;
  --color-surface-container-high: #e6e8f2;
  --color-surface-variant: #e0e2ec;

  --color-on-surface: #202124;
  --color-on-surface-variant: #414754;
  --color-text-secondary: #5F6368;
  --color-outline: #727785;
  --color-outline-variant: #c1c6d6;
  --color-border: #E8EAED;
  --color-chip-bg: #F1F3F4;

  background-color: var(--color-bg);
  color: var(--color-on-surface);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 排版 */
.h1 { font-size: 64rpx; font-weight: 700; line-height: 1.25; letter-spacing: -0.02em; color: var(--color-on-surface); }
.h2 { font-size: 48rpx; font-weight: 600; line-height: 1.33; letter-spacing: -0.01em; color: var(--color-on-surface); }
.h3 { font-size: 40rpx; font-weight: 600; line-height: 1.4; color: var(--color-on-surface); }
.body-lg { font-size: 36rpx; line-height: 1.55; color: var(--color-on-surface); }
.body-md { font-size: 32rpx; line-height: 1.5; color: var(--color-on-surface); }
.body-sm { font-size: 28rpx; line-height: 1.43; color: var(--color-on-surface-variant); }
.label-caps { font-size: 24rpx; font-weight: 600; letter-spacing: 0.05em; line-height: 1.33; color: var(--color-on-surface-variant); }
.text-muted { color: var(--color-text-secondary); }
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-secondary); }
.text-outline { color: var(--color-outline); }

/* 通用容器 */
.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* 顶部导航（非tabBar页的自定义头） */
.top-app-bar {
  position: sticky;
  top: 0;
  z-index: 40;
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 0 40rpx;
  height: 112rpx;
  background-color: var(--color-bg);
  border-bottom: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.top-app-bar .logo {
  font-family: "Space Grotesk", sans-serif;
  font-weight: 700;
  font-size: 40rpx;
  color: var(--color-primary);
}

.top-app-bar .avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 1rpx solid var(--color-outline-variant);
  background-color: var(--color-surface-variant);
  overflow: hidden;
}
.top-app-bar .avatar image { width: 100%; height: 100%; }

.top-app-bar .icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  background-color: transparent;
  padding: 0;
  border: none;
  line-height: 1;
}
.top-app-bar .icon-btn::after { border: none; }

/* 卡片 */
.card {
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

/* chip */
.chip {
  display: inline-flex;
  align-items: center;
  background-color: var(--color-chip-bg);
  color: var(--color-text-secondary);
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.chip.primary {
  background-color: var(--color-primary-tint);
  color: var(--color-primary);
}
.chip.success {
  background-color: var(--color-secondary-tint);
  color: var(--color-secondary);
}

/* 按钮 */
.btn-primary {
  background-color: var(--color-primary);
  color: #FFFFFF;
  padding: 20rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border: none;
}
.btn-primary::after { border: none; }

.btn-ghost {
  background-color: transparent;
  color: var(--color-primary);
  padding: 20rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 2rpx solid var(--color-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
.btn-ghost::after { border: none; }

/* 搜索框 */
.search-input {
  width: 100%;
  height: 80rpx;
  border-radius: 999rpx;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-outline-variant);
  padding: 0 32rpx 0 72rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: var(--color-on-surface);
}

/* 通用图标占位（iconfont/emoji simulation） */
.icon {
  width: 40rpx;
  height: 40rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* 安全距离 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* flex 辅助 */
.row { display: flex; align-items: center; }
.col { display: flex; flex-direction: column; }
.between { justify-content: space-between; }
.gap-xs { gap: 16rpx; }
.gap-sm { gap: 24rpx; }
.gap-md { gap: 32rpx; }
.gap-lg { gap: 48rpx; }

/* 隐藏滚动条 */
.hide-scrollbar ::-webkit-scrollbar { display: none; }
