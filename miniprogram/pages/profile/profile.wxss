.content {
  padding: 40rpx 40rpx 120rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

/* 资料头 */
.profile-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 0;
}
.avatar-btn {
  background: none;
  border: none;
  padding: 0;
  line-height: 1;
}
.avatar-btn::after { border: none; }
.avatar-wrap { position: relative; }
.avatar-edit-hint {
  position: absolute;
  bottom: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: rgba(0,0,0,0.7);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  white-space: nowrap;
}
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}
.quick-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 28rpx;
  background-color: var(--color-primary-tint);
  color: var(--color-primary);
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}
.qb-icon { font-size: 24rpx; }
.avatar-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 28rpx rgba(26,115,232,0.15);
  border: 8rpx solid var(--color-bg);
}
.avatar-initial {
  color: #FFFFFF;
  font-size: 80rpx;
  font-weight: 700;
  font-family: "Space Grotesk", sans-serif;
}
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.verified-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  border: 4rpx solid var(--color-bg);
}
.name-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  text-align: center;
}
.user-chips {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  justify-content: center;
}

/* 卡片通用 */
.stat-card, .skill-card, .career-card {
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(26,115,232,0.03);
}
.stat-head { display: flex; align-items: center; gap: 12rpx; }
.icon-box { font-size: 36rpx; color: var(--color-primary); }
.stat-sub {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
}

/* 学习记录 */
.stat-figure {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  margin-top: 32rpx;
}
.big-num {
  font-size: 96rpx;
  font-weight: 700;
  color: var(--color-on-surface);
  line-height: 1;
  font-family: "Space Grotesk", sans-serif;
}
.delta {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 26rpx;
  color: var(--color-secondary);
}

.progress-track {
  width: 100%;
  height: 12rpx;
  background-color: var(--color-surface-container-high);
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-track.success { background-color: #E8F5E9; }
.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  background-color: var(--color-primary);
}
.progress-fill.success { background-color: var(--color-secondary); }
.target-text {
  text-align: right;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--color-on-surface-variant);
}

/* 雷达 */
.radar-wrap {
  width: 100%;
  height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.radar-canvas { width: 100%; height: 100%; }
.radar-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: var(--color-primary-tint);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-top: 12rpx;
}
.radar-name { font-weight: 600; color: var(--color-primary); }
.radar-score { color: var(--color-primary); font-weight: 600; }

/* 职业发展 */
.career-title-pill {
  align-self: center;
  margin-top: 24rpx;
  background-color: var(--color-primary-tint);
  color: var(--color-primary);
  border: 2rpx solid rgba(26,115,232,0.2);
  border-radius: 999rpx;
  padding: 24rpx 48rpx;
  font-size: 40rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(26,115,232,0.1);
}
.career-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  margin-top: 24rpx;
}
.career-tag {
  background-color: var(--color-bg);
  border: 1rpx solid var(--color-outline-variant);
  color: var(--color-on-surface-variant);
  font-family: monospace;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 菜单 */
.menu-list {
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background-color: var(--color-surface-container-low); }
.menu-icon {
  width: 48rpx;
  text-align: center;
  color: var(--color-primary);
  font-size: 32rpx;
}
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-on-surface);
  margin-left: 16rpx;
}
.menu-arrow {
  font-size: 36rpx;
  color: var(--color-outline);
}
