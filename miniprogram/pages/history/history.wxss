page { background-color: var(--color-bg); }
.page {
  padding: 32rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}
.header { display: flex; flex-direction: column; gap: 8rpx; }
.h1 {
  font-size: 56rpx;
  font-weight: 700;
  font-family: "Space Grotesk", sans-serif;
}
.sub { font-size: 26rpx; color: var(--color-outline); }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 120rpx 0;
}
.empty-icon { font-size: 100rpx; opacity: 0.5; }
.empty-title { font-size: 32rpx; font-weight: 600; color: var(--color-on-surface-variant); }

.timeline {
  position: relative;
  padding-left: 32rpx;
  border-left: 2rpx solid var(--color-surface-container-high);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.day-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  position: relative;
}
.day-dot {
  position: absolute;
  left: -41rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  border: 4rpx solid var(--color-bg);
}
.day-label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 0.05em;
}
.day-items { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 16rpx; }

.record {
  display: flex;
  gap: 20rpx;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 16rpx;
  padding: 24rpx;
  align-items: center;
}
.record-type {
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.type-hotspot { background-color: #FFE7D6; color: var(--color-tertiary); }
.type-discussion { background-color: var(--color-primary-tint); color: var(--color-primary); }
.type-skill { background-color: var(--color-secondary-tint); color: var(--color-secondary); }
.type-path { background-color: #EDE7F6; color: #5E35B1; }

.record-body { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.record-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-on-surface);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.record-desc {
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.record-time { font-size: 22rpx; color: var(--color-outline); flex-shrink: 0; }

.list-footer {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-outline);
  padding: 24rpx 0;
}
