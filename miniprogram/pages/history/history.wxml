<view class="page">
  <view class="header">
    <text class="h1">浏览历史</text>
    <text class="sub">最近 {{total}} 条 · 仅自己可见</text>
  </view>

  <view wx:if="{{!loading && groups.length === 0}}" class="empty">
    <text class="empty-icon">📚</text>
    <text class="empty-title">还没有浏览记录</text>
  </view>

  <view class="timeline" wx:for="{{groups}}" wx:for-item="g" wx:key="dateKey">
    <view class="day-head">
      <text class="day-dot"></text>
      <text class="day-label">{{g.label}}</text>
    </view>
    <view class="day-items">
      <view
        class="record"
        wx:for="{{g.items}}"
        wx:for-item="item"
        wx:key="_id"
        bindtap="onItemTap"
        data-item="{{item}}"
      >
        <view class="record-type type-{{item.itemType}}">{{TYPE_LABEL[item.itemType] || item.itemType}}</view>
        <view class="record-body">
          <text class="record-title">{{item.title || item.itemId}}</text>
          <text wx:if="{{item.desc}}" class="record-desc">{{item.desc}}</text>
        </view>
        <text class="record-time">{{item._timeText}}</text>
      </view>
    </view>
  </view>

  <view class="list-footer" wx:if="{{loadingMore}}">加载中…</view>
  <view class="list-footer" wx:elif="{{!hasMore && groups.length > 0}}">没有更多了</view>
</view>
