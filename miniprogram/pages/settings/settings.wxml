<view class="page">
  <view class="section">
    <text class="section-title">账户</text>
    <view class="menu">
      <view class="menu-item" bindtap="onGoEdit">
        <text class="menu-icon">✎</text>
        <text class="menu-text">编辑资料</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onLogout">
        <text class="menu-icon">⎋</text>
        <text class="menu-text">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">缓存 & 数据</text>
    <view class="menu">
      <view class="menu-item" bindtap="onClearCache">
        <text class="menu-icon">🧹</text>
        <text class="menu-text">清理本地缓存</text>
        <text class="menu-value">{{cacheSizeText}}</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onClearHistory">
        <text class="menu-icon">🗑</text>
        <text class="menu-text">清空搜索历史</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">关于</text>
    <view class="menu">
      <view class="menu-item" bindtap="onAbout">
        <text class="menu-icon">ⓘ</text>
        <text class="menu-text">关于"见世界"</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onPrivacy">
        <text class="menu-icon">🔒</text>
        <text class="menu-text">隐私政策</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onAgreement">
        <text class="menu-icon">📄</text>
        <text class="menu-text">用户协议</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item static">
        <text class="menu-icon">🏷</text>
        <text class="menu-text">当前版本</text>
        <text class="menu-value">v{{version}}</text>
      </view>
    </view>
  </view>

  <view class="footer safe-bottom">
    <text>Made with 💙 for 大学生软件工程大赛</text>
  </view>
</view>
