page { background-color: var(--color-bg); }
.page {
  padding: 32rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.section { display: flex; flex-direction: column; gap: 16rpx; }
.section-title {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--color-outline);
  padding: 0 12rpx;
  text-transform: uppercase;
}

.menu {
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:not(.static):active { background-color: var(--color-surface-container-low); }

.menu-icon {
  width: 48rpx;
  font-size: 32rpx;
  color: var(--color-primary);
  text-align: center;
}
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-on-surface);
}
.menu-value {
  font-size: 26rpx;
  color: var(--color-outline);
  margin-right: 12rpx;
}
.menu-arrow {
  font-size: 36rpx;
  color: var(--color-outline);
}

.footer {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-outline);
  padding: 40rpx 0 16rpx;
}
