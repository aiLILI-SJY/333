.content {
  padding: 40rpx 40rpx 120rpx;
  display: flex;
  flex-direction: column;
  gap: 64rpx;
}

.section { display: flex; flex-direction: column; gap: 24rpx; }
.big-icon { font-size: 48rpx; color: var(--color-primary); }
.subtitle {
  font-size: 30rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.6;
}

/* 树卡片 */
.tree-card {
  position: relative;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 64rpx 40rpx 40rpx;
}
.refresh-indicator {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background-color: var(--color-surface-container-low);
  border: 1rpx solid var(--color-primary-fixed);
}
.pulse {
  position: relative;
  width: 16rpx;
  height: 16rpx;
}
.pulse-dot {
  position: absolute;
  inset: 0;
  background-color: var(--color-primary);
  border-radius: 50%;
}
.pulse-ring {
  position: absolute;
  inset: 0;
  background-color: var(--color-primary);
  border-radius: 50%;
  opacity: 0.7;
  animation: pulse 1.5s ease-out infinite;
}
@keyframes pulse {
  0% { transform: scale(1); opacity: 0.7; }
  80%, 100% { transform: scale(2); opacity: 0; }
}
.refresh-text {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--color-primary);
}

/* 路径节点列表 */
.path-list {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  padding-left: 40rpx;
  margin-top: 32rpx;
}
.path-node {
  position: relative;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.path-node.progress {
  border: 2rpx solid var(--color-primary);
  box-shadow: 0 8rpx 28rpx rgba(26,115,232,0.1);
  z-index: 2;
}
.path-node.locked { opacity: 0.65; }

/* 左侧连接线 */
.connector-line {
  position: absolute;
  left: -26rpx;
  top: -40rpx;
  width: 2rpx;
  height: 40rpx;
  background-color: var(--color-surface-container-high);
}

.connector-dot {
  position: absolute;
  left: -46rpx;
  top: 32rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 6rpx solid #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 22rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.connector-dot.done { background-color: var(--color-secondary); }
.connector-dot.progress { background-color: var(--color-primary); }
.connector-dot.locked { background-color: var(--color-outline-variant); }

.node-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.node-head { display: flex; flex-direction: column; gap: 12rpx; }
.node-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-on-surface);
}
.node-title.primary { color: var(--color-primary); }
.node-desc {
  font-size: 28rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.5;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
}
.tag.neutral {
  background-color: var(--color-surface-variant);
  color: var(--color-on-surface-variant);
}
.tag.warn {
  background-color: var(--color-error-container);
  color: var(--color-on-error-container);
}

/* 进度条 */
.progress-section { margin-top: 16rpx; }
.progress-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.progress-track {
  width: 100%;
  height: 12rpx;
  background-color: var(--color-surface-container-high);
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background-color: var(--color-primary);
  border-radius: 6rpx;
}

/* 节点右侧 */
.node-side {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}
.node-side.progress {
  background-color: var(--color-surface-container-low);
  border-radius: 10rpx;
  padding: 16rpx;
}
.side-box {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.side-text {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
}
.side-text.secondary { color: var(--color-secondary); }
.side-text.primary { color: var(--color-primary); }
.side-text.muted { color: var(--color-outline); }

.node-cta {
  background-color: var(--color-primary);
  color: #FFFFFF;
  text-align: center;
  padding: 16rpx 24rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
}
