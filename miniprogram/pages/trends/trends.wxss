.content {
  padding: 32rpx 40rpx 120rpx;
  display: flex;
  flex-direction: column;
  gap: 64rpx;
}

.section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.welcome-section { gap: 12rpx; }

.uppercase { text-transform: uppercase; }

.search-wrap {
  position: relative;
  margin-top: 20rpx;
}
.search-icon {
  position: absolute;
  left: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-outline);
  font-size: 34rpx;
  z-index: 2;
}
.search-input {
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.03);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.link {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  letter-spacing: 0.05em;
}

/* 横向滚动 */
.hotspot-scroll {
  width: 100%;
  white-space: nowrap;
  margin: 0 -40rpx;
  padding: 0 40rpx 16rpx;
  box-sizing: border-box;
}
.hotspot-list {
  display: inline-flex;
  gap: 32rpx;
}
.hotspot-card {
  width: 540rpx;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-sizing: border-box;
  white-space: normal;
}
.hotspot-cover {
  width: 100%;
  height: 240rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background-color: var(--color-surface-container);
}
.hotspot-cover image { width: 100%; height: 100%; }
.hotspot-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background-color: rgba(255,255,255,0.92);
  backdrop-filter: blur(8rpx);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.badge-dot { font-size: 20rpx; }
.badge-dot.fire { color: var(--color-tertiary-container); }
.badge-dot.up { color: var(--color-primary); }
.badge-text {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--color-on-surface);
}
.hotspot-title {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.4;
  color: var(--color-on-surface);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.hotspot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.mini-chip {
  background-color: var(--color-chip-bg);
  color: var(--color-text-secondary);
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--color-outline-variant);
}

/* 讨论列表 */
.discussion-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.discussion-item {
  display: flex;
  gap: 24rpx;
  padding: 28rpx;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 16rpx;
  align-items: flex-start;
}
.discussion-icon {
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.discussion-icon.primary { background-color: var(--color-primary-fixed); color: var(--color-primary); }
.discussion-icon.neutral { background-color: var(--color-surface-container); color: var(--color-on-surface-variant); }
.discussion-icon.success { background-color: #5cfd80; color: var(--color-secondary); }

.fav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-outline);
  flex-shrink: 0;
}
.fav-btn.active { color: #F5B400; }
.fav-btn:active { opacity: 0.6; }

.discussion-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
}
.discussion-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}
.read-time {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
}
.discussion-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.35;
  color: var(--color-on-surface);
}
.list-footer {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-outline);
  padding: 24rpx 0;
}

.discussion-desc {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
