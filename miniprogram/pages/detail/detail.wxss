page {
  background-color: var(--color-bg);
}

.page {
  padding: 32rpx 40rpx 200rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

/* Hero */
.hero {
  background: linear-gradient(135deg, var(--color-primary-tint) 0%, var(--color-bg) 100%);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.hero-discussion { background: linear-gradient(135deg, #E8F5E9 0%, var(--color-bg) 100%); }
.hero-skill { background: linear-gradient(135deg, #FFF3E0 0%, var(--color-bg) 100%); }
.hero-path { background: linear-gradient(135deg, #EDE7F6 0%, var(--color-bg) 100%); }

.type-chip {
  align-self: flex-start;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background-color: rgba(26,115,232,0.12);
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
}
.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.3;
  color: var(--color-on-surface);
  font-family: "Space Grotesk", sans-serif;
}
.hero-sub {
  font-size: 30rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.5;
}
.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}
.hero-tag {
  background-color: rgba(255,255,255,0.8);
  color: var(--color-text-secondary);
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid var(--color-outline-variant);
}

.gen-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed var(--color-outline-variant);
  font-size: 22rpx;
  color: var(--color-outline);
}
.regen-btn {
  color: var(--color-primary);
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  background-color: rgba(26,115,232,0.08);
}

/* 加载 */
.loading-card {
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}
.spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--color-surface-container);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-on-surface);
}
.loading-sub {
  font-size: 24rpx;
  color: var(--color-outline);
}

/* 错误 */
.error-card {
  background-color: #FFF3F3;
  border: 1rpx solid #FFD0D0;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.error-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-error);
}
.error-msg {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  text-align: center;
}
.retry-btn {
  margin-top: 16rpx;
  padding: 16rpx 40rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-radius: 16rpx;
  font-weight: 600;
}

/* Sections */
.sections {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 40rpx;
}
.section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.section-h {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-primary);
  font-family: "Space Grotesk", sans-serif;
}
.section-body {
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--color-on-surface);
}

/* 子卡片 */
.sub-card {
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  padding: 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.sub-card.highlight {
  background-color: var(--color-primary-tint);
  border-color: rgba(26,115,232,0.2);
}
.sub-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-on-surface-variant);
  letter-spacing: 0.05em;
}
.chip-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
.chip {
  background-color: var(--color-chip-bg);
  color: var(--color-text-secondary);
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.chip.primary {
  background-color: rgba(26,115,232,0.12);
  color: var(--color-primary);
}

/* Takeaways */
.takeaway-list { display: flex; flex-direction: column; gap: 16rpx; }
.takeaway {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}
.takeaway-dot {
  color: var(--color-primary);
  font-size: 28rpx;
  margin-top: 4rpx;
}
.takeaway-body {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-on-surface);
}

.info-line {
  padding: 24rpx 32rpx;
  background-color: var(--color-surface-container-low);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
}

/* Path 模块 */
.overview {
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  padding: 32rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--color-on-surface);
}
.modules {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.module {
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-left: 8rpx solid var(--color-primary);
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.module-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.module-no {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-family: "Space Grotesk", sans-serif;
  font-size: 24rpx;
}
.module-title-col {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.module-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-on-surface);
}
.module-weeks {
  font-size: 22rpx;
  color: var(--color-outline);
  font-family: monospace;
}
.module-topics {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-left: 84rpx;
}
.topic {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.5;
}
.module-project {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background-color: var(--color-secondary-tint);
  border-radius: 12rpx;
  margin-left: 84rpx;
}
.project-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-secondary);
  letter-spacing: 0.05em;
}
.project-body {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
}
.outcome-body {
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--color-on-surface);
}

/* Footer */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-border);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.04);
}
.fav-action {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 80rpx;
  border-radius: 16rpx;
  border: 2rpx solid var(--color-outline-variant);
  color: var(--color-on-surface-variant);
  font-weight: 600;
  font-size: 28rpx;
}
.fav-action.active {
  background-color: #FFF8E1;
  border-color: #F5B400;
  color: #F5B400;
}
.fav-icon { font-size: 36rpx; }

.share-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-weight: 600;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  line-height: 1;
  padding: 0;
}
.share-btn::after { border: none; }
.share-icon { font-size: 32rpx; }
