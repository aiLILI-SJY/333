.skeleton {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  padding: 32rpx 40rpx;
}
.sk-hotspot-row {
  display: flex;
  gap: 24rpx;
}
.sk-card {
  flex-shrink: 0;
  width: 460rpx;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.sk-cover {
  height: 220rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #EEE 0%, #F5F5F5 50%, #EEE 100%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s infinite;
}
.sk-line {
  height: 24rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #EEE 0%, #F5F5F5 50%, #EEE 100%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s infinite;
}
.w30 { width: 30%; }
.w40 { width: 40%; }
.w60 { width: 60%; }
.w80 { width: 80%; }

.sk-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.sk-item {
  display: flex;
  gap: 24rpx;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 16rpx;
  padding: 28rpx;
}
.sk-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #EEE 0%, #F5F5F5 50%, #EEE 100%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s infinite;
}
.sk-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

@keyframes sk-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
